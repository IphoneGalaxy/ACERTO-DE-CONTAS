# =========================
# Fixtures de teste (apenas sintéticos versionados)
# =========================
test/fixtures/*.csv
test/fixtures/*.xlsx
test/fixtures/*.xls
test/fixtures/*.pdf
test/fixtures/*.ofx
!test/fixtures/README.md
!test/fixtures/*.sintetico.csv

